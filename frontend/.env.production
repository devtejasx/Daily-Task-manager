# Frontend Environment Configuration - PRODUCTION

# API Configuration
# ⚠️ REPLACE WITH YOUR BACKEND URL AFTER DEPLOYMENT
NEXT_PUBLIC_API_URL=https://YOUR-BACKEND-URL-HERE.herokuapp.com/api
NEXT_PUBLIC_WEB_SOCKET_URL=wss://YOUR-BACKEND-URL-HERE.herokuapp.com

# Environment  
NEXT_PUBLIC_ENVIRONMENT=production

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_AI_FEATURES=true
NEXT_PUBLIC_ENABLE_VOICE_INPUT=true
NEXT_PUBLIC_ENABLE_TEAM_FEATURES=true

# Analytics
NEXT_PUBLIC_GA_ID=

# App Configuration
NEXT_PUBLIC_APP_NAME=TaskMaster
NEXT_PUBLIC_APP_VERSION=1.0.0

# NOTE: This file should NOT be committed with sensitive data
# Netlify will override these values with environment variables set in the dashboard
